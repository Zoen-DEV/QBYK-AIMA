# Copia este archivo a .env y rellena tus credenciales

# Blotato API Key (obligatorio)
# Obtener en: https://my.blotato.com/settings/api
BLOTATO_API_KEY=your_blotato_api_key_here

# LLM para escribir los posts (al menos uno requerido)
# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Perplexity (alternativa, usa sonar-pro) — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# IDs de cuentas para publicar (opcional)
# Si se dejan vacíos, la API los lista automáticamente al primer job.
BLOTATO_LINKEDIN_ACCOUNT_ID=
BLOTATO_INSTAGRAM_ACCOUNT_ID=

# Generación de imágenes (opcional) — Higgsfield Soul
# Si defines AMBAS (key + secret), las imágenes se generan con Higgsfield Soul
# (mejor calidad/realismo, de pago, asíncrono). Si falta cualquiera de las dos,
# se usa Pollinations.ai (FLUX), que es gratis y no requiere API key.
# Credenciales en: https://cloud.higgsfield.ai/
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=
# Overrides opcionales (tienen defaults sensatos):
# HIGGSFIELD_MODEL=higgsfield-ai/soul/standard
# HIGGSFIELD_RESOLUTION=1080p

# Generación de VIDEO (opcional) — Higgsfield text-to-video
# Solo se usa cuando el job pide "tipo de medio: video". Requiere las MISMAS
# credenciales de arriba (HIGGSFIELD_API_KEY + HIGGSFIELD_API_SECRET); no hay
# fallback gratis para video (Pollinations no genera video). Si el video falla,
# el job avisa y se queda sin medio en esa publicación.
# Verifica el slug del modelo de video en tu catálogo de Higgsfield y ajústalo aquí:
# HIGGSFIELD_VIDEO_MODEL=higgsfield-ai/text2video/turbo
# HIGGSFIELD_VIDEO_ASPECT=9:16        # 16:9 | 4:3 | 1:1 | 9:16 (un solo clip se comparte LinkedIn+Instagram)
# HIGGSFIELD_VIDEO_DURATION=          # vacío = duración por defecto del modelo
