# Copia este archivo a .env y rellena tus credenciales

# Blotato API Key (obligatorio)
# Obtener en: https://my.blotato.com/settings/api
BLOTATO_API_KEY=your_blotato_api_key_here

# LLM para escribir los posts (al menos uno requerido)
# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Groq (alternativa gratuita, usa llama-3.3-70b) — https://console.groq.com/keys
GROQ_API_KEY=

# IDs de cuentas para publicar (opcional)
# Si se dejan vacíos, la API los lista automáticamente al primer job.
BLOTATO_LINKEDIN_ACCOUNT_ID=
BLOTATO_INSTAGRAM_ACCOUNT_ID=

# Freepik API Key — genera imágenes con Freepik Mystic (opcional)
# Si falta, se publican posts sin imagen.
# Obtener en: https://www.freepik.com/api
FREEPIK_API_KEY=
