---
import Base from "../../layouts/Base.astro";
import ProgressView from "../../components/ProgressView";
const { id } = Astro.params;
if (!id) return Astro.redirect("/");
---

<Base title="Generando post...">
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-white mb-1">Generando tu contenido</h1>
      <p class="text-gray-400 text-sm">Esto puede tomar varios minutos.</p>
    </div>
    <ProgressView client:load jobId={id} apiUrl="/api" />
  </div>
</Base>
